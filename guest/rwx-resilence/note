kubectl -n longhorn-system get svc lh-share-manager-svc
kubectl -n longhorn-system get endpoints lh-share-manager-svc -o yaml
kubectl -n longhorn-system get endpointslice -l kubernetes.io/service-name=lh-share-manager-svc -o yaml

kubectl -n longhorn-system get pod nfs-proxy -o wide
kubectl -n longhorn-system describe pod nfs-proxy
kubectl -n longhorn-system debug -it pod/nfs-proxy --target=haproxy --image=nicolaka/netshoot -- /bin/bash
    ip addr
    ip route
    cat /etc/resolv.conf

    nc -vz lh-share-manager-svc.longhorn-system.svc.cluster.local 2049

    nc -vz lh-share-manager-headless.longhorn-system.svc.cluster.local 2049

in VM
